RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect www to the root domain (https://pandit.guru)
RewriteCond %{HTTP_HOST} ^www\.pandit\.guru$ [NC]
RewriteRule ^(.*)$ https://pandit.guru/$1 [L,R=301]

# News & Blog SPA (React, built from news-blog-app/) — served at /news-blog
# and its admin panel at /admin. Both paths render the same shell file;
# client-side routing inside the SPA decides what to show. Real files
# (admin-api/*, content-api/*, lib/*, image.php, blog-app-assets/*) are left
# alone by the -f checks below.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(news-blog|admin)(/.*)?$ /blog-app.html [L]

# Default document
DirectoryIndex index.html

# Basic caching for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
