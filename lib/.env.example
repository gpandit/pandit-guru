# Per-environment secrets and configuration for the News & Blog PHP backend.
#
# Copy this file to `.env` (same directory) and fill in REAL values. `.env`
# is gitignored — never committed.

SITE_NAME=Pandit Guru
SITE_URL=https://pandit.guru
DEBUG_ERRORS=false

# Generate a hash on the host with:
#   php -r "echo password_hash('your-password', PASSWORD_DEFAULT), PHP_EOL;"
ADMIN_PASSWORD_HASH=
ADMIN_ACCOUNT=admin@pandit.guru
MFA_ISSUER=Pandit Guru Admin

# Create an empty MySQL database + user (e.g. in hPanel -> Databases), then
# fill these in. Tables are created automatically on first connection.
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# Generate ONCE for this environment and keep secret:
#   php -r "echo base64_encode(sodium_crypto_secretbox_keygen()), PHP_EOL;"  # ENCRYPTION_KEY (32 bytes)
#   php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"                   # BLIND_INDEX_KEY
# WARNING: if ENCRYPTION_KEY is lost, encrypted data is unrecoverable.
ENCRYPTION_KEY=
BLIND_INDEX_KEY=

# SMTP (admin invite/reset emails only)
MAIL_HOST=smtp-pulse.com
MAIL_PORT=465
MAIL_USER=
MAIL_PASS=
MAIL_FROM=hello@pandit.guru
MAIL_FROM_NAME=Pandit Guru
